# helper to normalize SQL placeholders for sqlite/psycopg2
def sqlp(s: str) -> str:
    # sqlite uses "?", psycopg2 uses "%s"
    return s.replace("?", "%s") if is_pg() else s

@app.route("/")
@login_required
def index():
    conn = create_connection()
    cur = conn.cursor()

    cur.execute(sqlp("SELECT * FROM vehicles"))
    vehicles = cur.fetchall()

    # column names
    columns = [col[0] for col in cur.description]

    vehicle_list = []
    for row in vehicles:
        vehicle = dict(zip(columns, row))

        cur.execute(sqlp("SELECT photo FROM vehicle_photos WHERE vehicle_id=?"), (vehicle["id"],))
        photos = cur.fetchall()
        vehicle["first_photo"] = photos[0][0] if photos else None

        vehicle_list.append(vehicle)

    conn.close()
    return render_template("index.html", vehicles=vehicle_list)

@app.route("/add", methods=["GET", "POST"])
@login_required
def add_vehicle():
    if request.method == "POST":
        marca = request.form.get("marca")
        modelo = request.form.get("modelo")
        CC = request.form.get("CC")
        cor = request.form.get("cor")
        matricula = request.form.get("matricula")
        ano = request.form.get("ano")
        num_lugares = request.form.get("num_lugares")
        local_garagem = request.form.get("local_garagem")
        estado_geral = request.form.get("estado_geral")

        conn = create_connection()
        cur = conn.cursor()

        cur.execute(sqlp("""
            INSERT INTO vehicles (marca, modelo, CC, cor, matricula, ano, num_lugares, local_garagem, estado_geral)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        """), (marca, modelo, CC, cor, matricula, ano, num_lugares, local_garagem, estado_geral))
        conn.commit()

        if is_pg():
            cur.execute(sqlp("""
                INSERT INTO vehicles (marca, modelo, CC, cor, matricula, ano, num_lugares, local_garagem, estado_geral)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
                RETURNING id
            """), (marca, modelo, CC, cor, matricula, ano, num_lugares, local_garagem, estado_geral))
            vehicle_id = cur.fetchone()[0]
        else:
            cur.execute(sqlp("""
                INSERT INTO vehicles (marca, modelo, CC, cor, matricula, ano, num_lugares, local_garagem, estado_geral)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """), (marca, modelo, CC, cor, matricula, ano, num_lugares, local_garagem, estado_geral))
            vehicle_id = cur.lastrowid


        photos = request.files.getlist("photos")
        for photo in photos:
            if photo and photo.filename:
                # save file
                file_path = os.path.join(app.config["UPLOAD_FOLDER"], photo.filename)
                photo.save(file_path)
                # record
                cur.execute(sqlp("INSERT INTO vehicle_photos (vehicle_id, photo) VALUES (?, ?)"),
                            (vehicle_id, photo.filename))

        conn.commit()
        conn.close()
        return redirect(url_for("index"))

    return render_template("create_vehicle.html")

@app.route("/edit/<int:vehicle_id>", methods=["GET", "POST"])
@login_required
def edit_vehicle(vehicle_id):
    conn = create_connection()
    cur = conn.cursor()

    cur.execute(sqlp("SELECT * FROM vehicles WHERE id=?"), (vehicle_id,))
    vehicle = cur.fetchone()
    if vehicle is None:
        conn.close()
        flash("Vehicle not found", "error")
        return redirect(url_for("index"))

    columns = [c[0] for c in cur.description]
    vehicle_dict = dict(zip(columns, vehicle))

    cur.execute(sqlp("SELECT photo FROM vehicle_photos WHERE vehicle_id=?"), (vehicle_id,))
    photos = cur.fetchall()
    vehicle_dict["photos"] = [p[0] for p in photos]

    if request.method == "POST":
        marca = request.form["marca"]
        modelo = request.form["modelo"]
        CC = request.form["CC"]
        cor = request.form["cor"]
        matricula = request.form["matricula"]
        ano = request.form["ano"]
        num_lugares = request.form["num_lugares"]
        local_garagem = request.form["local_garagem"]
        estado_geral = request.form["estado_geral"]

        cur.execute(sqlp("""
            UPDATE vehicles
               SET marca=?, modelo=?, CC=?, cor=?, matricula=?, ano=?, num_lugares=?, local_garagem=?, estado_geral=?
             WHERE id=?
        """), (marca, modelo, CC, cor, matricula, ano, num_lugares, local_garagem, estado_geral, vehicle_id))

        # deletes
        photos_to_delete = request.form.getlist("photos_to_delete")
        for p in photos_to_delete:
            cur.execute(sqlp("DELETE FROM vehicle_photos WHERE photo=? AND vehicle_id=?"), (p, vehicle_id))
            fs_path = os.path.join(app.config["UPLOAD_FOLDER"], p)
            if os.path.exists(fs_path):
                try:
                    os.remove(fs_path)
                except Exception:
                    pass

        # new photos
        new_photos = request.files.getlist("photos")
        for photo in new_photos:
            if photo and photo.filename:
                file_path = os.path.join(app.config["UPLOAD_FOLDER"], photo.filename)
                photo.save(file_path)
                cur.execute(sqlp("INSERT INTO vehicle_photos (vehicle_id, photo) VALUES (?, ?)"),
                            (vehicle_id, photo.filename))

        conn.commit()
        conn.close()
        flash("Vehicle updated successfully!", "success")
        return redirect(url_for("index"))

    conn.close()
    return render_template("edit_vehicle.html", vehicle=vehicle_dict)

@app.route("/delete/<int:vehicle_id>", methods=["GET", "POST"])
@login_required
def delete_vehicle(vehicle_id):
    conn = create_connection()
    cur = conn.cursor()

    cur.execute(sqlp("SELECT photo FROM vehicle_photos WHERE vehicle_id=?"), (vehicle_id,))
    photos = cur.fetchall()

    cur.execute(sqlp("DELETE FROM vehicle_photos WHERE vehicle_id=?"), (vehicle_id,))
    cur.execute(sqlp("DELETE FROM vehicles WHERE id=?"), (vehicle_id,))
    conn.commit()
    conn.close()

    for (photo_name,) in photos:
        photo_path = os.path.join(app.config["UPLOAD_FOLDER"], photo_name)
        if os.path.exists(photo_path):
            try:
                os.remove(photo_path)
            except Exception:
                pass

    flash("Vehicle and its photos deleted successfully!", "success")
    return redirect(url_for("index"))

